---
import { readFileSync, existsSync } from 'fs';
import { join } from 'path';
import yaml from 'js-yaml';
import sharp from 'sharp';
import Clock from '../components/Clock.svelte';
import UrlLauncher from '../components/UrlLauncher.svelte';

interface App {
	name: string;
	url: string;
	logo: string;
	color?: string;
}

interface Category {
	name: string;
	apps: App[];
}

interface Config {
	categories: Category[];
}

function getSaturation(r: number, g: number, b: number): number {
	const rn = r / 255, gn = g / 255, bn = b / 255;
	const max = Math.max(rn, gn, bn), min = Math.min(rn, gn, bn);
	const l = (max + min) / 2;
	if (max === min) return 0;
	const d = max - min;
	return l > 0.5 ? d / (2 - max - min) : d / (max + min);
}

async function getImageBuffer(logo: string): Promise<Buffer | null> {
	if (logo.startsWith('http://') || logo.startsWith('https://')) {
		try {
			const res = await fetch(logo);
			if (!res.ok) return null;
			return Buffer.from(await res.arrayBuffer());
		} catch {
			return null;
		}
	}
	const fullPath = join(process.cwd(), 'public', logo);
	if (!existsSync(fullPath)) return null;
	return readFileSync(fullPath);
}

async function extractColor(logo: string, fallback = '#ffffff'): Promise<string> {
	const buffer = await getImageBuffer(logo);
	if (!buffer) return fallback;

	try {
		const { data } = await sharp(buffer)
			.resize(64, 64, { fit: 'fill' })
			.ensureAlpha()
			.raw()
			.toBuffer({ resolveWithObject: true });

		let bestR = 128, bestG = 128, bestB = 128, bestScore = -1;

		for (let i = 0; i < data.length; i += 4) {
			const r = data[i], g = data[i + 1], b = data[i + 2], a = data[i + 3];
			if (a < 128) continue;

			const rn = r / 255, gn = g / 255, bn = b / 255;
			const l = (Math.max(rn, gn, bn) + Math.min(rn, gn, bn)) / 2;
			if (l < 0.15 || l > 0.92) continue;

			const s = getSaturation(r, g, b);
			if (s > bestScore) {
				bestScore = s;
				bestR = r; bestG = g; bestB = b;
			}
		}

		return `#${bestR.toString(16).padStart(2, '0')}${bestG.toString(16).padStart(2, '0')}${bestB.toString(16).padStart(2, '0')}`;
	} catch {
		return fallback;
	}
}

const YOUTUBE_REDIRECT = 'https://www.youtube.com/redirect?q=';

const configPath = join(process.cwd(), 'src/data/config.yml');
const raw = readFileSync(configPath, 'utf-8');
const config = yaml.load(raw) as Config;

const categories = await Promise.all(
	config.categories.map(async (cat) => ({
		...cat,
		apps: await Promise.all(
			cat.apps.map(async (app) => ({
				...app,
				color: await extractColor(app.logo, app.color ?? '#ffffff'),
				href: `${YOUTUBE_REDIRECT}${encodeURIComponent(app.url)}`
			}))
		)
	}))
);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Tesflix</title>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	</head>

	<body>
		<div class="ambient" aria-hidden="true">
			<div class="blob blob-1"></div>
			<div class="blob blob-2"></div>
			<div class="blob blob-3"></div>
		</div>

		<main>
			<header>
				<h1 class="logo">
					<img src="/logos/tesflix.png" alt="Tesflix" class="logo-img" />
				</h1>
				<Clock client:load />
			</header>

			<div class="launcher-wrap">
				<UrlLauncher client:load />
			</div>

			<div id="categories">
			{categories.map((cat) => (
				<section class="category" data-category={cat.name}>
					<h2 class="category-title">
						<span class="drag-handle" aria-hidden="true">
							<svg viewBox="0 0 24 24" fill="currentColor"><circle cx="9" cy="5" r="1.5"/><circle cx="15" cy="5" r="1.5"/><circle cx="9" cy="12" r="1.5"/><circle cx="15" cy="12" r="1.5"/><circle cx="9" cy="19" r="1.5"/><circle cx="15" cy="19" r="1.5"/></svg>
						</span>
						{cat.name}
					</h2>
					<div class="grid">
						{cat.apps.map((app) => (
							<a
								href={app.href}
								target="_blank"
								rel="noopener noreferrer"
								class="card"
								style={`--app-color: ${app.color};`}
							>
								<span class="spotlight" aria-hidden="true"></span>
								<span class="border-glow" aria-hidden="true"></span>
								<div class="card-inner">
									<div class="icon-wrap">
										<img
											src={app.logo}
											alt={`${app.name} logo`}
											width="80"
											height="80"
											onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
										/>
										<span class="icon-fallback" style={`color: ${app.color};`}>
											{app.name[0]}
										</span>
									</div>
									<p class="app-name">{app.name}</p>
								</div>
							</a>
						))}
					</div>
				</section>
			))}
			</div>

			<footer>
				Tesflix &mdash; {new Date().getFullYear()}
			</footer>
		</main>

		<script>
			const cards = document.querySelectorAll<HTMLElement>('.card');

			function applySpotlight(card: HTMLElement, clientX: number, clientY: number) {
				const rect = card.getBoundingClientRect();
				card.style.setProperty('--mouse-x', `${((clientX - rect.left) / rect.width) * 100}%`);
				card.style.setProperty('--mouse-y', `${((clientY - rect.top) / rect.height) * 100}%`);
			}

			cards.forEach((card) => {
				card.addEventListener('mousemove', (e: MouseEvent) => applySpotlight(card, e.clientX, e.clientY));

				card.addEventListener('touchmove', (e: TouchEvent) => {
					e.preventDefault();
					applySpotlight(card, e.touches[0].clientX, e.touches[0].clientY);
				}, { passive: false });

				card.addEventListener('touchstart', (e: TouchEvent) => {
					applySpotlight(card, e.touches[0].clientX, e.touches[0].clientY);
					card.classList.add('touching');
				}, { passive: true });

				card.addEventListener('touchend', () => {
					card.classList.remove('touching');
					card.style.setProperty('--mouse-x', '50%');
					card.style.setProperty('--mouse-y', '50%');
				});
			});

			const STORAGE_KEY = 'tesflix-category-order';
			const container = document.getElementById('categories') as HTMLElement;

			function getSections() {
				return [...container.querySelectorAll<HTMLElement>('.category')];
			}

			function saveOrder() {
				const order = getSections().map(s => s.dataset.category!);
				localStorage.setItem(STORAGE_KEY, JSON.stringify(order));
			}

			function restoreOrder() {
				const saved = localStorage.getItem(STORAGE_KEY);
				if (!saved) return;
				const order: string[] = JSON.parse(saved);
				order.forEach(name => {
					const el = container.querySelector<HTMLElement>(`[data-category="${name}"]`);
					if (el) container.appendChild(el);
				});
			}

			function insertAdjacent(dragged: HTMLElement, target: HTMLElement, clientY: number) {
				if (dragged === target) return;
				const rect = target.getBoundingClientRect();
				if (clientY < rect.top + rect.height / 2) {
					container.insertBefore(dragged, target);
				} else {
					container.insertBefore(dragged, target.nextSibling);
				}
			}

			let dragging: HTMLElement | null = null;

			getSections().forEach((section) => {
				const handle = section.querySelector<HTMLElement>('.drag-handle')!;
				handle.style.cursor = 'grab';

				section.addEventListener('dragstart', (e: DragEvent) => {
					dragging = section;
					section.classList.add('is-dragging');
					e.dataTransfer!.effectAllowed = 'move';
				});

				section.addEventListener('dragend', () => {
					dragging = null;
					section.classList.remove('is-dragging');
					document.querySelectorAll('.drop-indicator').forEach(el => el.remove());
					saveOrder();
				});

				section.addEventListener('dragover', (e: DragEvent) => {
					e.preventDefault();
					if (dragging) insertAdjacent(dragging, section, e.clientY);
				});
			});

			getSections().forEach(section => {
				const handle = section.querySelector<HTMLElement>('.drag-handle')!;
				handle.addEventListener('mousedown', () => { section.draggable = true; });
				document.addEventListener('mouseup', () => { section.draggable = false; });
			});

			let touchDragging: HTMLElement | null = null;
			let ghost: HTMLElement | null = null;
			let touchOffsetY = 0;

			getSections().forEach(section => {
				const handle = section.querySelector<HTMLElement>('.drag-handle')!;

				handle.addEventListener('touchstart', (e: TouchEvent) => {
					const touch = e.touches[0];
					touchDragging = section;
					touchOffsetY = touch.clientY - section.getBoundingClientRect().top;

					ghost = section.cloneNode(true) as HTMLElement;
					ghost.classList.add('touch-ghost');
					ghost.style.width = section.offsetWidth + 'px';
					ghost.style.top = (touch.clientY - touchOffsetY) + 'px';
					ghost.style.left = section.getBoundingClientRect().left + 'px';
					document.body.appendChild(ghost);

					section.classList.add('is-dragging');
					e.preventDefault();
				}, { passive: false });
			});

			document.addEventListener('touchmove', (e: TouchEvent) => {
				if (!touchDragging || !ghost) return;
				const touch = e.touches[0];

				ghost.style.top = (touch.clientY - touchOffsetY) + 'px';

				ghost.style.display = 'none';
				const el = document.elementFromPoint(touch.clientX, touch.clientY);
				ghost.style.display = '';
				const target = el?.closest<HTMLElement>('.category');
				if (target && target !== touchDragging) {
					insertAdjacent(touchDragging, target, touch.clientY);
				}
			}, { passive: true });

			document.addEventListener('touchend', () => {
				if (!touchDragging) return;
				touchDragging.classList.remove('is-dragging');
				ghost?.remove();
				ghost = null;
				touchDragging = null;
				saveOrder();
			});

			restoreOrder();
		</script>
	</body>
</html>

<style is:global>
	@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap');

	*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

	:root {
		--bg: #0A0A0F;
		--surface: rgba(255, 255, 255, 0.04);
		--border: rgba(255, 255, 255, 0.08);
		--text: #F8FAFC;
		--muted: #64748b;
		--red: #E50914;
	}

	body {
		background-color: var(--bg);
		color: var(--text);
		font-family: 'Inter', system-ui, sans-serif;
		min-height: 100dvh;
		-webkit-font-smoothing: antialiased;
		overflow-x: hidden;
	}

	/* ── Ambient background ── */
	.ambient {
		position: fixed;
		inset: 0;
		pointer-events: none;
		z-index: 0;
		overflow: hidden;
	}

	.blob {
		position: absolute;
		border-radius: 50%;
		filter: blur(120px);
		opacity: 0.18;
	}

	.blob-1 {
		width: 600px; height: 600px;
		background: #E50914;
		top: -200px; left: -100px;
	}

	.blob-2 {
		width: 500px; height: 500px;
		background: #312E81;
		bottom: -150px; right: -100px;
	}

	.blob-3 {
		width: 400px; height: 400px;
		background: #0EA5E9;
		top: 40%; left: 50%;
		transform: translate(-50%, -50%);
		opacity: 0.08;
	}

	/* ── Layout ── */
	main {
		position: relative;
		z-index: 1;
		max-width: 1800px;
		margin: 0 auto;
		padding: 2.5rem 2.5rem;
	}

	/* ── Header ── */
	header {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		margin-bottom: 3rem;
	}

	.logo {
		grid-column: 2;
		justify-self: center;
		margin: 0;
		line-height: 0;
	}

	.logo-img {
		height: clamp(7rem, 18vw, 16rem);
		width: auto;
		object-fit: contain;
		filter: drop-shadow(0 0 40px rgba(229, 9, 20, 0.5));
	}

	header :global(.clock) {
		grid-column: 3;
		justify-self: end;
	}

	/* ── Drag & drop ── */
	.drag-handle {
		display: inline-flex;
		align-items: center;
		padding: 2px 4px;
		margin-right: 0.5rem;
		border-radius: 4px;
		color: #334155;
		cursor: grab;
		transition: color 150ms ease;
		vertical-align: middle;
		touch-action: none;
	}

	.drag-handle:hover { color: #64748b; }
	.drag-handle:active { cursor: grabbing; }

	.drag-handle svg {
		width: 14px;
		height: 14px;
		display: block;
	}

	.category.is-dragging {
		opacity: 0.35;
	}

	/* Ghost element during touch drag */
	:global(.touch-ghost) {
		position: fixed;
		z-index: 999;
		pointer-events: none;
		opacity: 0.85;
		box-shadow: 0 20px 60px rgba(0,0,0,0.6);
		border-radius: 12px;
		background: #0A0A0F;
		overflow: hidden;
	}

	/* ── URL Launcher ── */
	.launcher-wrap {
		margin-bottom: 2.5rem;
	}

	/* ── Categories ── */
	.category {
		margin-bottom: 2.5rem;
	}

	.category-title {
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: #64748b;
		margin-bottom: 1rem;
		padding-left: 0.25rem;
		border-left: 3px solid #E50914;
		padding-left: 0.75rem;
	}

	/* ── Grid ── */
	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
		gap: 1.25rem;
	}

	/* Large screens (Tesla ~1920px) */
	@media (min-width: 1400px) {
		.grid {
			grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
			gap: 1.5rem;
		}
	}

	/* Tablet / landscape */
	@media (max-width: 768px) {
		.grid {
			grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
			gap: 1rem;
		}
	}

	/* Small mobile */
	@media (max-width: 480px) {
		.grid {
			grid-template-columns: repeat(2, 1fr);
			gap: 0.75rem;
		}
	}

	/* ── Card ── */
	.card {
		--mouse-x: 50%;
		--mouse-y: 50%;
		--app-color: #fff;

		position: relative;
		border-radius: 20px;
		background: var(--surface);
		border: 1px solid var(--border);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		overflow: hidden;
		text-decoration: none;
		cursor: pointer;
		transition: transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease;
		aspect-ratio: 1;
		/* Minimum tap target size */
		min-height: 160px;
	}

	.card:hover {
		transform: scale(1.04) translateY(-3px);
		border-color: color-mix(in srgb, var(--app-color) 50%, transparent);
		box-shadow:
			0 0 0 1px color-mix(in srgb, var(--app-color) 20%, transparent),
			0 24px 48px -12px color-mix(in srgb, var(--app-color) 35%, transparent),
			0 0 100px -20px color-mix(in srgb, var(--app-color) 20%, transparent);
	}

	.card:active,
	.card.touching {
		transform: scale(0.96);
	}

	.card.touching .spotlight {
		opacity: 1;
	}

	.card.touching .border-glow {
		opacity: 1;
	}

	/* Spotlight radial gradient follows cursor */
	.spotlight {
		position: absolute;
		inset: 0;
		opacity: 0;
		transition: opacity 300ms ease;
		background: radial-gradient(
			circle at var(--mouse-x) var(--mouse-y),
			color-mix(in srgb, var(--app-color) 15%, transparent) 0%,
			transparent 60%
		);
		pointer-events: none;
		border-radius: inherit;
	}

	.card:hover .spotlight {
		opacity: 1;
	}

	/* Animated border glow */
	.border-glow {
		position: absolute;
		inset: -1px;
		border-radius: inherit;
		background: radial-gradient(
			circle at var(--mouse-x) var(--mouse-y),
			color-mix(in srgb, var(--app-color) 40%, transparent),
			transparent 60%
		);
		opacity: 0;
		transition: opacity 300ms ease;
		pointer-events: none;
		z-index: -1;
	}

	.card:hover .border-glow {
		opacity: 1;
	}

	/* Card content */
	.card-inner {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 1rem;
		height: 100%;
		padding: 1.5rem;
	}

	.icon-wrap {
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}

	.icon-wrap img {
		width: 80px;
		height: 80px;
		object-fit: contain;
		transition: transform 200ms ease;
	}

	.card:hover .icon-wrap img {
		transform: scale(1.08);
	}

	.icon-fallback {
		display: none;
		align-items: center;
		justify-content: center;
		width: 80px;
		height: 80px;
		font-size: 3rem;
		font-weight: 700;
	}

	.app-name {
		font-size: 1rem;
		font-weight: 600;
		color: rgba(248, 250, 252, 0.9);
		text-align: center;
		line-height: 1.3;
		letter-spacing: 0.02em;
	}

	@media (min-width: 1400px) {
		.icon-wrap img { width: 100px; height: 100px; }
		.icon-fallback { width: 100px; height: 100px; font-size: 3.5rem; }
		.app-name { font-size: 1.1rem; }
		.card-inner { gap: 1.25rem; padding: 2rem; }
	}

	@media (max-width: 480px) {
		.icon-wrap img { width: 60px; height: 60px; }
		.icon-fallback { width: 60px; height: 60px; font-size: 2.25rem; }
		.app-name { font-size: 0.875rem; }
	}

	/* ── Footer ── */
	footer {
		margin-top: 3rem;
		text-align: center;
		font-size: 0.7rem;
		color: var(--muted);
		letter-spacing: 0.05em;
	}

	/* ── Reduced motion ── */
	@media (prefers-reduced-motion: reduce) {
		.card { transition: none; }
		.spotlight, .border-glow { transition: none; }
	}
</style>
